Subject: Fix setup.py to find parser.c + scanner.c in dual-grammar subdirs

Upstream v0.5.3 GitHub release tarball ships the dual-grammar
subdirectory layout (tree-sitter-markdown/src/ + tree-sitter-markdown-inline/src/)
but setup.py was restructured between v0.5.1 and v0.5.3 to expect
a flat src/parser.c + src/scanner.c at the top level. Reverting
the setup.py to the working v0.5.1 shape (build both grammars
together into the single _binding extension; copy queries from
both subdirectories) lets the GitHub-source build succeed.

Reported upstream — should be unnecessary once upstream either:
  (a) restores PyPI publishing with a working flat-layout sdist; or
  (b) ships a v0.5.4+ that aligns setup.py with the GitHub tarball.

--- a/setup.py
+++ b/setup.py
@@ -10,9 +10,12 @@
 
 class Build(build):
     def run(self):
-        if path.isdir("queries"):
-            dest = path.join(self.build_lib, "tree_sitter_markdown", "queries")
-            self.copy_tree("queries", dest)
+        if path.isdir("tree-sitter-markdown/queries"):
+            dest = path.join(self.build_lib, "tree_sitter_markdown", "queries", "markdown")
+            self.copy_tree("tree-sitter-markdown/queries", dest)
+        if path.isdir("tree-sitter-markdown-inline/queries"):
+            dest = path.join(self.build_lib, "tree_sitter_markdown", "queries", "markdown_inline")
+            self.copy_tree("tree-sitter-markdown-inline/queries", dest)
         super().run()
 
 
@@ -22,8 +25,6 @@
             ext.extra_compile_args = ["-std=c11", "-fvisibility=hidden"]
         else:
             ext.extra_compile_args = ["/std:c11", "/utf-8"]
-        if path.exists("src/scanner.c"):
-            ext.sources.append("src/scanner.c")
         if ext.py_limited_api:
             ext.define_macros.append(("Py_LIMITED_API", "0x030A0000"))
         super().build_extension(ext)
@@ -40,8 +41,10 @@
 class EggInfo(egg_info):
     def find_sources(self):
         super().find_sources()
-        self.filelist.recursive_include("queries", "*.scm")
-        self.filelist.include("src/tree_sitter/*.h")
+        self.filelist.recursive_include("tree-sitter-markdown/queries", "*.scm")
+        self.filelist.recursive_include("tree-sitter-markdown-inline/queries", "*.scm")
+        self.filelist.include("tree-sitter-markdown/src/tree_sitter/*.h")
+        self.filelist.include("tree-sitter-markdown-inline/src/tree_sitter/*.h")
 
 
